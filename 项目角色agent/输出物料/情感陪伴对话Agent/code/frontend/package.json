{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:stt": "conda run -n liminal-stt uvicorn main:app --host 0.0.0.0 --port 8001 --workers 1 --log-level info",
    "dev:tts": "conda run -n liminal-tts uvicorn main:app --host 0.0.0.0 --port 8002 --workers 1 --log-level info",
    "dev:all": "concurrently -n \"next,stt,tts\" -c \"cyan,green,yellow\" \"pnpm dev\" \"pnpm dev:stt\" \"pnpm dev:tts\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/react": "^3.0.147",
    "@auth/core": "^0.34.3",
    "ai": "^6.0.145",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.7",
    "next": "16.2.2",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "concurrently": "^9.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}